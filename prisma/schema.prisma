generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String
  phone         String?
  role          Role           @default(BUYER)
  storeName     String?
  storeSlug     String?        @unique
  storeDesc     String?
  storeLogo     String?
  shippingAddress String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]
  products      Product[]      @relation("SellerProducts")
  wallets       Wallet[]       @relation("BuyerWallets")

  @@index([storeSlug])
}

model Product {
  id                String           @id @default(cuid())
  name              String
  description       String?
  imageUrl          String?
  price             Float
  quantity          Int?
  planType          PaymentPlanType  @default(FLEXIBLE)
  lockFunds         Boolean          @default(true)
  installmentAmount Float?
  interval          PaymentInterval?
  durationCount     Int?
  allowOverpay      Boolean          @default(true)
  allowUnderpay     Boolean          @default(false)
  isActive          Boolean          @default(true)
  sellerId          String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  seller            User             @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: Cascade)
  wallets           Wallet[]

  @@index([sellerId])
  @@index([isActive])
}

model Wallet {
  id              String       @id @default(cuid())
  totalPrice      Float
  amountPaid      Float        @default(0)
  balance         Float
  progressPercent Float        @default(0)
  status          WalletStatus @default(ACTIVE)
  buyerName       String
  buyerPhone      String
  buyerAddress    String
  quantity        Int          @default(1)
  buyerId         String
  productId       String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  points          Int          @default(0)
  payments        Payment[]
  buyer           User         @relation("BuyerWallets", fields: [buyerId], references: [id], onDelete: Cascade)
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([buyerId, productId])
  @@index([buyerId])
  @@index([productId])
  @@index([status])
}

model Payment {
  id         String        @id @default(cuid())
  amount     Float
  status     PaymentStatus @default(PENDING)
  reference  String        @unique
  paystackId String?
  walletId   String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  wallet     Wallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([reference])
  @@index([status])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  userId    String
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

enum Role {
  SELLER
  BUYER
}

enum PaymentPlanType {
  FIXED
  FLEXIBLE
}

enum PaymentInterval {
  DAILY
  WEEKLY
  MONTHLY
}

enum WalletStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum NotificationType {
  PAYMENT_RECEIVED
  PAYMENT_CONFIRMED
  WALLET_COMPLETED
  GENERAL
}
