# Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/glotta?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Paystack
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Cloudinary (optional - for product images)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Resend (transactional email)
RESEND_API_KEY=""

# Termii (SMS - Nigeria)
TERMII_API_KEY=""
TERMII_SENDER_ID="Glotta"
